{
  "name": "boredgame",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "scripts": {
    "dev:sample": "pnpm --filter simple-project dev",
    "dev:saboteur": "pnpm --filter saboteur-project dev",
    "build": "turbo run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "turbo": "^2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
